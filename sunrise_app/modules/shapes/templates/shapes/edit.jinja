{% block script %}

<script src="{{url_for('shapes.static', filename='js/blockly_compressed.js')}}"></script>
<script src="{{url_for('shapes.static', filename='js/blockly_field_dependent_dropdown.js')}}"></script>
<script src="{{url_for('shapes.static', filename='js/blockly_blocks.js')}}"></script>
<script src="{{url_for('shapes.static', filename='js/blockly_msg_en.js')}}"></script>
<script src="{{url_for('shapes.static', filename='js/blockly_python.js')}}"></script>
<script src="{{url_for('shapes.static', filename='js/custom_blocks.js')}}"></script>

<script>
    function initializeBlockly() {
        var options = {
            toolbox: document.getElementById("toolbox"),
            collapse: false,
            comments: false,
            disable: false,
            maxBlocks: Infinity,
            trashcan: true,
            horizontalLayout: false,
            toolboxPosition: 'start',
            css: true,
            rtl: false,
            scrollbars: false,
            sounds: true,
            oneBasedIndex: true,
            grid: {
                spacing: 20,
                length: 3,
                colour: '#ccc',
                snap: true
            },
            zoom: {
                controls: true,
                wheel: true,
                pinch: true,
                startScale: 1.3
            },
            move: {
                scrollbars: {
                    horizontal: true,
                    vertical: true
                },
                drag: true,
                wheel: false
            }
        };

        var workspace = Blockly.inject('blocklyDiv', options);

        {% if state %}
            var initState = JSON.parse({{ state | tojson }});
            Blockly.serialization.workspaces.load(initState, workspace);
        {% endif %}

        return workspace;
    }

    function checkFloatingBlocks(workspace){
        const topBlocks = workspace.getTopBlocks(true);

        for (i in topBlocks){           
            if (functionBlockNames.indexOf(topBlocks[i].type) == -1){ 
                return "Make sure all blocks are inside Loop or another function";
            }
        }
        return "";
    }

    function checkVariablesName(workspace){
        const variables = workspace.getAllVariableNames();
        const errors = [];

        for (let i in variables){
            if (reservedWords.indexOf(variables[i]) > -1){
                errors.push(`You cannot name a variable <b>${variables[i]}</b>, please rename it.`)
            }
        }

        return errors;
    }

    function checkFunctionsName(workspace){
        const functions = workspace
            .getBlocksByType("procedures_defnoreturn")
            .concat(
                workspace.getBlocksByType("procedures_defreturn")
            );
        const errors = [];

        for (n in functions){
            if (reservedWords.indexOf(functions[n]) > -1){
                errors.push(functions[n])
            }
        }

        return errors;
    }

    function getSubscriptions(workspace){
        const functions = workspace.getBlocksByType("mqtt_subscribe");

        return functions.map(block => {
            const topic = block.getInputTargetBlock("topic").getFieldValue("TEXT");
            const payload_reference = block.getField("var_name").getVariable().name;
            return {"topic": topic, "function": clean_topic_names(topic), "payload_reference": payload_reference};
        });
    }

    function getRos2Publishers(workspace){
        const functions = workspace.getBlocksByType("ros2_publish");

        return functions.map(block => {
            const topic = block.getInputTargetBlock("topic").getFieldValue("TEXT");
            const message_type = block.getInputTargetBlock("message_type").getFieldValue("message_type");
            return {"topic": topic, "message_type": message_type};
        });
    }

    function getRos2Subscriptions(workspace){
        const functions = workspace.getBlocksByType("ros2_subscribe");

        return functions.map(block => {
            const topic = block.getInputTargetBlock("topic").getFieldValue("TEXT");
            const message_type = block.getInputTargetBlock("message_type").getFieldValue("message_type");
            const payload_reference = block.getField("var_name").getVariable().name;
            return {"topic": topic, "function": clean_topic_names(topic), "message_type": message_type, "payload_reference": payload_reference};
        });
    }
    
    function validateShape(workspace){

        const errors_variables = checkVariablesName(workspace);
        const errors = checkFunctionsName(workspace);
        const floatingBlocksError = checkFloatingBlocks(workspace);

        if (floatingBlocksError.length > 0) {
            toast(floatingBlocksError, "danger");
        }

        for (let i in errors_variables){
            toast(errors_variables[i], "danger");
        }

        for (let i in errors){
            toast(errors[i], "danger");
        }

        return errors.length == 0 && errors_variables.length == 0 && floatingBlocksError.length == 0;
    }

    function setGeneratedCode(workspace) {
        Blockly.Python.addReservedWords('code');
        const code = python.pythonGenerator.workspaceToCode(workspace);
        let origin = code.indexOf("# Shapes");
        const imports_and_libraries = defineImportsAndLibraries();
        $('#generatedCode').val(imports_and_libraries + code.substring(origin));
    }

    function setState(workspace) {
        const state = Blockly.serialization.workspaces.save(workspace);
        $('#state').val(JSON.stringify(state));
    }

    function setSubscriptions(subscriptions) {
        $('#subscriptions').val(JSON.stringify(subscriptions));
    }

    const reservedWords = ["sunrise_app_function","zion","code","logging_queue","debug","data", "main","tskin","tspeech","gesture","ironboy","touch","braccio"];
    const functionBlockNames = ["sunrise_app_function", "sunrise_app_setup", "sunrise_app_close", "procedures_defnoreturn", "variables_set", "procedures_defreturn", "mqtt_subscribe", "ros2_subscribe"];

    $(document).ready(async function () {

        loadCustomBlocks({{ blocks_config | tojson | safe }});
        defineCustomGenerators();

        const workspace = initializeBlockly();

        $('#update-program-form').on('submit', (e) => {

            try{
                if(!validateShape(workspace)){
                    e.preventDefault();
                    return false;
                }
                
                const subscriptions = getSubscriptions(workspace);
                const ros2subscriptions = getRos2Subscriptions(workspace);
                const ros2publishers = getRos2Publishers(workspace);

                console.log(ros2subscriptions);
                console.log(ros2publishers);

                setGeneratedCode(workspace);
                setState(workspace);
                setSubscriptions(subscriptions);
                $('#subscriptions').val(JSON.stringify(subscriptions));
                $('#ros2_subscriptions').val(JSON.stringify(ros2subscriptions));
                $('#ros2_publishers').val(JSON.stringify(ros2publishers));
            }
            catch(ex){
                e.preventDefault();
                console.log(ex);
                return false;
            }
            return true;
        });
    });
</script>
{% endblock %}