                        </shadow>
                    </value>
                </block>
                <block type="ros2_publish">
                    <value name="payload">
                        <shadow type="text">
                        </shadow>
                    </value>
                    <value name="topic">
                        <shadow type="text">
                        </shadow>
                    </value>
                    <value name="message_type">
                        <shadow type="ros2_message_type">
                        </shadow>
                    </value>
