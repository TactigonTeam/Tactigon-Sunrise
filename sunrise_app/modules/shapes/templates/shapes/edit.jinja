        {% if current_config.mqtt_config %}
            <sep></sep>
            <category name="MQTT" colour="#6665DD">
                <block type="mqtt_subscribe">
                    <value name="topic">
                        <shadow type="text">
                        </shadow>
                    </value>
                </block>
                <block type="mqtt_publish">
                    <value name="payload">
                        <shadow type="text">
                        </shadow>
                    </value>
                    <value name="topic">
