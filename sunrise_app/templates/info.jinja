{% extends "settings.jinja" %}

{% block settings %}
    <div class="container p-3">
        <div class="card m-auto w-50">
            <div class="card-body">
                <div class="d-flex flex-column align-content-center text-center gap-3">
                    <img src="{{ url_for('static', filename='images/logo.png') }}" class="mx-auto d-block my-4" height="80px" width="80px">
                    <p class="h3">Sunrise App</p>
                    <p>Version: {{ version }}</p>
                </div>
            </div>
        </div>
    </div>
    
{% endblock settings %}